# ═══════════════════════════════════════════════
# RouterAI - Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ API Key ของคุณ
# ═══════════════════════════════════════════════

# ⚡ Groq (แนะนำ! เร็วสุด ฟรี)
# สมัคร: https://console.groq.com/keys
GROQ_API_KEY=

# 🟢 Google Gemini (ฟรี 15 RPM, รองรับ Vision)
# สมัคร: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# 🚀 Cerebras (เร็วมาก ฟรี)
# สมัคร: https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# 🌐 OpenRouter (โมเดลฟรีเยอะ)
# สมัคร: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# 🟣 Mistral
# สมัคร: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# 🔵 NVIDIA NIM (Llama ฟรี)
# สมัคร: https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=

# 💎 DeepSeek (คุณภาพสูง)
# สมัคร: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# 🤝 Together AI ($5 เครดิตฟรี)
# สมัคร: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# 🇨🇳 SiliconFlow (Qwen ฟรี)
# สมัคร: https://cloud.siliconflow.cn
SILICONFLOW_API_KEY=
